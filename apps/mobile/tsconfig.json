{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@temperature-blanket/core": [
        "../../packages/core/src/index.ts"
      ],
      "@temperature-blanket/core/*": [
        "../../packages/core/src/*"
      ]
    }
  },
  "include": [
